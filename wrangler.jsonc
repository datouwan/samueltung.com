{
  // Personal site for samueltung.com — static-assets-only Worker.
  "name": "samueltung-com",
  "compatibility_date": "2025-09-23",
  "assets": {
    "directory": "./public",
    "not_found_handling": "404-page"
  },

  // ── Custom domains ──
  "routes": [
    { "pattern": "samueltung.com",     "custom_domain": true },
    { "pattern": "www.samueltung.com", "custom_domain": true }
  ]
}
